---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { entrySlug, formatDate, formatReadingTime, slugify, truncate, withBase } from "../utils/helpers";

interface Props {
  article: CollectionEntry<"articles">;
  compact?: boolean;
}

const { article, compact = false } = Astro.props;

const articleHref = withBase(`/makaleler/${entrySlug(article.id)}/`);
const categoryHref = withBase(`/kategori/${slugify(article.data.category)}/`);
const imageSrc = article.data.heroImage ?? "/images/uploads/site-preview.svg";
---

{
  compact ? (
    <article class="group surface-card overflow-hidden">
      <a href={articleHref} class="grid gap-0 sm:grid-cols-[148px_1fr]">
        <div class="overflow-hidden">
          <Image
            src={imageSrc}
            alt={article.data.title}
            width={480}
            height={320}
            class="h-full min-h-36 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
          />
        </div>
        <div class="space-y-3 p-5">
          <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
            <span>{formatDate(article.data.pubDate)}</span>
            <span class="h-1 w-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
            <span>{formatReadingTime(article.body ?? article.data.description)}</span>
          </div>
          <h3 class="font-display text-lg font-semibold text-slate-900 group-hover:text-brand-800 dark:text-white dark:group-hover:text-accent-300">
            {article.data.title}
          </h3>
          <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">{truncate(article.data.description, 120)}</p>
        </div>
      </a>
    </article>
  ) : (
    <article class="group surface-card overflow-hidden">
      <a href={articleHref} class="block">
        <div class="overflow-hidden">
          <Image
            src={imageSrc}
            alt={article.data.title}
            width={1200}
            height={675}
            class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-[1.04]"
          />
        </div>
        <div class="space-y-4 p-6">
          <div class="flex flex-wrap items-center gap-3 text-xs">
            <span class="rounded-full bg-accent-500/10 px-3 py-1 font-semibold text-accent-500">{article.data.category}</span>
            <span class="text-slate-500 dark:text-slate-400">{formatDate(article.data.pubDate)}</span>
            <span class="text-slate-500 dark:text-slate-400">{formatReadingTime(article.body ?? article.data.description)}</span>
          </div>
          <h3 class="font-display text-2xl font-semibold leading-snug text-slate-900 group-hover:text-brand-800 dark:text-white dark:group-hover:text-accent-300">
            {article.data.title}
          </h3>
          <p class="line-clamp-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{article.data.description}</p>
        </div>
      </a>
      <div class="border-t border-slate-200/80 px-6 py-4 text-sm dark:border-slate-800">
        <a href={categoryHref} class="font-medium text-slate-600 hover:text-brand-900 dark:text-slate-300 dark:hover:text-accent-300">
          {article.data.category} arşivini görüntüle
        </a>
      </div>
    </article>
  )
}
