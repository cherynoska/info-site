<button
  type="button"
  class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white/80 text-slate-700 shadow-sm hover:border-accent-500/50 hover:text-brand-900 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100"
  data-theme-toggle
  aria-label="Koyu modu aç"
  title="Tema değiştir"
>
  <svg data-theme-icon="sun" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25M12 18.75V21M4.97 4.97l1.59 1.59M17.44 17.44l1.59 1.59M3 12h2.25M18.75 12H21M4.97 19.03l1.59-1.59M17.44 6.56l1.59-1.59M15.75 12A3.75 3.75 0 1 1 8.25 12a3.75 3.75 0 0 1 7.5 0Z" />
  </svg>
  <svg data-theme-icon="moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3c-.18.78-.27 1.6-.27 2.46A9 9 0 0 0 21 12.79Z" />
  </svg>
</button>

<script is:inline>
  const getPreferredTheme = () => {
    const storedTheme = localStorage.getItem("theme");
    if (storedTheme === "light" || storedTheme === "dark") return storedTheme;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };

  const applyThemeState = (button, theme) => {
    const isDark = theme === "dark";
    button?.setAttribute("aria-label", isDark ? "Açık modu aç" : "Koyu modu aç");
    button?.querySelector('[data-theme-icon="sun"]')?.classList.toggle("hidden", !isDark);
    button?.querySelector('[data-theme-icon="moon"]')?.classList.toggle("hidden", isDark);
  };

  for (const button of document.querySelectorAll("[data-theme-toggle]")) {
    if (button.dataset.ready === "true") continue;
    button.dataset.ready = "true";

    applyThemeState(button, getPreferredTheme());
    button.addEventListener("click", () => {
      const nextTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
      document.documentElement.classList.toggle("dark", nextTheme === "dark");
      localStorage.setItem("theme", nextTheme);
      applyThemeState(button, nextTheme);
    });
  }
</script>
