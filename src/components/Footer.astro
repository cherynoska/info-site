---
import settings from "../data/settings.json";
import { withBase } from "../utils/helpers";

const navigationItems = settings.navigation ?? [];
const footerLinks = settings.footerLinks ?? [];
const socialLinks = settings.socialLinks ?? [];
---

<footer class="border-t border-slate-200/80 bg-white/80 py-12 dark:border-slate-800 dark:bg-slate-950/90" data-pagefind-ignore>
  <div class="container-shell grid gap-10 lg:grid-cols-[1.35fr_1fr_1fr]">
    <div class="space-y-4">
      <p class="section-eyebrow">{settings.footerEyebrow || settings.siteTitle}</p>
      <h2 class="font-display text-2xl font-semibold text-slate-900 dark:text-white">{settings.siteTitle}</h2>
      <p class="max-w-xl text-sm leading-7 text-slate-600 dark:text-slate-300">{settings.siteDescription}</p>
    </div>

    <div class="space-y-4">
      <h3 class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Keşfet</h3>
      <ul class="space-y-3 text-sm">
        {
          navigationItems.map((item) => (
            <li>
              <a href={withBase(item.href)} class="text-slate-600 hover:text-brand-900 dark:text-slate-300 dark:hover:text-accent-300">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="space-y-4">
      <h3 class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Bağlantılar</h3>
      <ul class="space-y-3 text-sm">
        {
          footerLinks.map((item) => (
            <li>
              <a href={withBase(item.href)} class="text-slate-600 hover:text-brand-900 dark:text-slate-300 dark:hover:text-accent-300">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex flex-wrap gap-3 pt-2">
        {
          socialLinks.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center rounded-full border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 hover:border-accent-500/50 hover:text-brand-900 dark:border-slate-700 dark:text-slate-200 dark:hover:text-accent-300"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="container-shell mt-10 flex flex-col gap-2 border-t border-slate-200/80 pt-6 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {new Date().getFullYear()} {settings.siteTitle}. Tüm hakları saklıdır.</p>
    <p>{settings.footerLegalText}</p>
  </div>
</footer>
