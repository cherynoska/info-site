---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="surface-card group h-full p-6">
  <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-900/8 text-brand-900 group-hover:-translate-y-1 dark:bg-accent-500/10 dark:text-accent-300">
    <slot name="icon" />
  </div>
  <h3 class="font-display text-xl font-semibold text-slate-900 dark:text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{description}</p>
</article>
