<button
  type="button"
  class="fixed bottom-6 right-6 z-40 hidden h-12 w-12 items-center justify-center rounded-full bg-brand-900 text-white shadow-xl shadow-brand-900/30 hover:-translate-y-1 dark:bg-accent-500 dark:text-brand-950"
  data-scroll-top
  aria-label="Yukarı çık"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
    <path stroke-linecap="round" stroke-linejoin="round" d="m6 15 6-6 6 6" />
  </svg>
</button>

<script is:inline>
  for (const button of document.querySelectorAll("[data-scroll-top]")) {
    if (button.dataset.ready === "true") continue;
    button.dataset.ready = "true";

    const syncState = () => {
      button.classList.toggle("hidden", window.scrollY < 420);
      button.classList.toggle("flex", window.scrollY >= 420);
    };

    syncState();
    window.addEventListener("scroll", syncState, { passive: true });
    button.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
  }
</script>
