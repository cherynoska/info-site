---
import type { CollectionEntry } from "astro:content";
import SearchBar from "./SearchBar.astro";
import { entrySlug, formatDate, withBase } from "../utils/helpers";

interface CountItem {
  value: string;
  slug: string;
  count: number;
}

interface Props {
  categories: CountItem[];
  tags: CountItem[];
  recentArticles?: CollectionEntry<"articles">[];
}

const { categories, tags, recentArticles = [] } = Astro.props;
---

<aside class="space-y-6">
  <SearchBar />

  <section class="surface-card p-5">
    <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white">Kategoriler</h3>
    <ul class="mt-4 space-y-3">
      {
        categories.map((category) => (
          <li>
            <a
              href={withBase(`/kategori/${category.slug}/`)}
              class="flex items-center justify-between rounded-2xl border border-slate-200/70 px-4 py-3 text-sm text-slate-700 hover:border-accent-500/40 hover:text-brand-900 dark:border-slate-800 dark:text-slate-200 dark:hover:text-accent-300"
            >
              <span>{category.value}</span>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                {category.count}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="surface-card p-5">
    <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white">Popüler etiketler</h3>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <a
            href={withBase(`/etiket/${tag.slug}/`)}
            class="rounded-full border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:border-accent-500/50 hover:text-brand-900 dark:border-slate-700 dark:text-slate-200 dark:hover:text-accent-300"
          >
            #{tag.value}
          </a>
        ))
      }
    </div>
  </section>

  {
    recentArticles.length > 0 && (
      <section class="surface-card p-5">
        <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white">Son yazılar</h3>
        <div class="mt-4 space-y-4">
          {
            recentArticles.map((article) => (
              <a href={withBase(`/makaleler/${entrySlug(article.id)}/`)} class="block rounded-2xl border border-slate-200/70 p-4 hover:border-accent-500/40 dark:border-slate-800">
                <div class="text-xs text-slate-500 dark:text-slate-400">{formatDate(article.data.pubDate)}</div>
                <div class="mt-2 font-medium text-slate-800 dark:text-slate-100">{article.data.title}</div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-accent-500">{article.data.category}</div>
              </a>
            ))
          }
        </div>
      </section>
    )
  }
</aside>
