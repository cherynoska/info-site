---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  member: CollectionEntry<"team">;
  bio: string;
}

const { member, bio } = Astro.props;
const socials = [
  { label: "X", href: member.data.social.twitter },
  { label: "LinkedIn", href: member.data.social.linkedin },
  { label: "GitHub", href: member.data.social.github }
].filter((item) => item.href);
---

<article class="surface-card overflow-hidden">
  <Image src={member.data.photo} alt={member.data.name} width={640} height={640} class="aspect-square w-full object-cover" />
  <div class="space-y-4 p-6">
    <div>
      <h3 class="font-display text-2xl font-semibold text-slate-900 dark:text-white">{member.data.name}</h3>
      <p class="mt-1 text-sm font-semibold uppercase tracking-[0.2em] text-accent-500">{member.data.title}</p>
    </div>
    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">{bio}</p>
    <div class="flex flex-wrap gap-2">
      {
        socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:border-accent-500/50 hover:text-brand-900 dark:border-slate-700 dark:text-slate-200 dark:hover:text-accent-300"
          >
            {social.label}
          </a>
        ))
      }
    </div>
  </div>
</article>
