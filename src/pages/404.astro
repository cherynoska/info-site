---
import BaseLayout from "../layouts/BaseLayout.astro";
import pageSettings from "../data/page-settings.json";
import { withBase } from "../utils/helpers";
---

<BaseLayout
  title="Sayfa Bulunamadı"
  description={pageSettings.notFound.description}
  canonicalPath="/404/"
  searchable={false}
  noindex={true}
>
  <section class="container-shell flex min-h-[70vh] items-center py-12">
    <div class="surface-card mx-auto max-w-3xl px-8 py-12 text-center">
      <p class="section-eyebrow">{pageSettings.notFound.eyebrow}</p>
      <h1 class="mt-5 font-display text-5xl font-semibold text-slate-950 dark:text-white sm:text-6xl">{pageSettings.notFound.title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{pageSettings.notFound.description}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={withBase(pageSettings.notFound.primaryHref)} class="button-primary">{pageSettings.notFound.primaryLabel}</a>
        <a href={withBase(pageSettings.notFound.secondaryHref)} class="button-secondary">{pageSettings.notFound.secondaryLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
