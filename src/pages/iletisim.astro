---
import { getCollection, render } from "astro:content";
import ContactForm from "../components/ContactForm.astro";
import PageLayout from "../layouts/PageLayout.astro";
import pageSettings from "../data/page-settings.json";
import settings from "../data/settings.json";
import { entrySlug } from "../utils/helpers";

const page = (await getCollection("pages")).find((entry) => entrySlug(entry.id) === "iletisim");

if (!page) {
  throw new Error("İletişim içeriği bulunamadı.");
}

const { Content } = await render(page);
---

<PageLayout
  title={page.data.title}
  description={page.data.description}
  eyebrow={pageSettings.contact.eyebrow}
  canonicalPath="/iletisim/"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: page.data.title,
    description: page.data.description
  }}
>
  <Content />

  <Fragment slot="afterContent">
    <section class="container-shell mt-12 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-6">
        <article class="surface-card p-6">
          <p class="section-eyebrow">{pageSettings.contact.infoEyebrow}</p>
          <div class="mt-5 space-y-5 text-sm leading-7 text-slate-600 dark:text-slate-300">
            <div>
              <div class="font-semibold text-slate-900 dark:text-white">{pageSettings.contact.emailLabel}</div>
              <a href={`mailto:${settings.contactEmail}`} class="hover:text-brand-900 dark:hover:text-accent-300">
                {settings.contactEmail}
              </a>
            </div>
            <div>
              <div class="font-semibold text-slate-900 dark:text-white">{pageSettings.contact.phoneLabel}</div>
              <a href={`tel:${settings.phone.replace(/\s+/g, "")}`} class="hover:text-brand-900 dark:hover:text-accent-300">
                {settings.phone}
              </a>
            </div>
            <div>
              <div class="font-semibold text-slate-900 dark:text-white">{pageSettings.contact.addressLabel}</div>
              <p>{settings.address}</p>
            </div>
          </div>
        </article>

        <article class="surface-card p-6">
          <p class="section-eyebrow">{pageSettings.contact.mapEyebrow}</p>
          <div class="mt-5 flex min-h-72 items-center justify-center rounded-[1.75rem] border border-dashed border-slate-300 bg-slate-100 text-center text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400">
            {pageSettings.contact.mapPlaceholder}
          </div>
        </article>
      </div>

      <ContactForm action={settings.formAction} />
    </section>
  </Fragment>
</PageLayout>
