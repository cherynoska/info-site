---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import ShareButtons from "../components/ShareButtons.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ArticleCard from "../components/ArticleCard.astro";
import BaseLayout from "./BaseLayout.astro";
import settings from "../data/settings.json";
import { absoluteUrl, entrySlug, formatDate, formatReadingTime, getInitials, slugify, withBase } from "../utils/helpers";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  article: CollectionEntry<"articles">;
  headings: Heading[];
  relatedArticles: CollectionEntry<"articles">[];
  authorMember?: CollectionEntry<"team">;
  newerArticle?: CollectionEntry<"articles">;
  olderArticle?: CollectionEntry<"articles">;
}

const { article, headings, relatedArticles, authorMember, newerArticle, olderArticle } = Astro.props;

const canonicalPath = `/makaleler/${entrySlug(article.id)}/`;
const shareUrl = Astro.site ? absoluteUrl(canonicalPath, Astro.site) : withBase(canonicalPath);
const articleImage = article.data.heroImage ?? "/images/uploads/site-preview.svg";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.data.title,
    description: article.data.description,
    datePublished: article.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: authorMember?.data.name ?? article.data.author
    },
    publisher: {
      "@type": "Organization",
      name: settings.siteTitle,
      logo: {
        "@type": "ImageObject",
        url: Astro.site ? absoluteUrl(settings.logo || "/images/uploads/site-logo.svg", Astro.site) : withBase(settings.logo || "/images/uploads/site-logo.svg")
      }
    },
    image: Astro.site ? absoluteUrl(articleImage, Astro.site) : withBase(articleImage),
    mainEntityOfPage: shareUrl
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Ana Sayfa",
        item: Astro.site ? absoluteUrl("/", Astro.site) : withBase("/")
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Makaleler",
        item: Astro.site ? absoluteUrl("/makaleler/", Astro.site) : withBase("/makaleler/")
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.data.title,
        item: shareUrl
      }
    ]
  }
];
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  image={articleImage}
  type="article"
  canonicalPath={canonicalPath}
  searchable={true}
  structuredData={structuredData}
  publishedTime={article.data.pubDate}
>
  <div class="fixed left-0 right-0 top-0 z-50 h-1 bg-transparent" data-pagefind-ignore>
    <div class="h-full w-0 bg-accent-500 shadow-[0_0_20px_rgba(22,199,154,0.5)]" data-scroll-progress></div>
  </div>

  <section class="container-shell py-10 lg:py-14">
    <nav class="mb-8 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href={withBase("/")} class="hover:text-brand-900 dark:hover:text-accent-300">Ana Sayfa</a>
      <span>/</span>
      <a href={withBase("/makaleler/")} class="hover:text-brand-900 dark:hover:text-accent-300">Makaleler</a>
      <span>/</span>
      <span class="text-slate-700 dark:text-slate-200">{article.data.title}</span>
    </nav>

    <div class="grid gap-10 xl:grid-cols-[minmax(0,1fr)_300px]">
      <article class="min-w-0">
        <div class="overflow-hidden rounded-[2rem] border border-white/60 bg-white/85 shadow-xl shadow-slate-200/50 dark:border-slate-800 dark:bg-slate-900/85">
          <Image src={articleImage} alt={article.data.title} width={1600} height={900} class="aspect-[16/9] w-full object-cover" />
        </div>

        <header class="mt-8 space-y-6">
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <a href={withBase(`/kategori/${slugify(article.data.category)}/`)} class="rounded-full bg-accent-500/10 px-4 py-2 font-semibold text-accent-500">
              {article.data.category}
            </a>
            <span class="text-slate-500 dark:text-slate-400">{formatDate(article.data.pubDate)}</span>
            <span class="text-slate-500 dark:text-slate-400">{formatReadingTime(article.body ?? article.data.description)}</span>
          </div>

          <div class="space-y-4">
            <h1 class="max-w-4xl font-display text-4xl font-semibold leading-tight text-slate-950 dark:text-white sm:text-5xl">
              {article.data.title}
            </h1>
            <p class="max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">{article.data.description}</p>
          </div>

          <div class="flex items-center gap-4 rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-4 dark:border-slate-800 dark:bg-slate-900/80">
            {
              authorMember?.data.photo ? (
                <Image src={authorMember.data.photo} alt={authorMember.data.name} width={80} height={80} class="h-16 w-16 rounded-2xl object-cover" />
              ) : (
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-brand-900 text-lg font-semibold text-white dark:bg-accent-500 dark:text-brand-950">
                  {getInitials(article.data.author)}
                </div>
              )
            }
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Yazar</div>
              <div class="mt-1 font-display text-xl font-semibold text-slate-900 dark:text-white">
                {authorMember?.data.name ?? article.data.author}
              </div>
              <div class="text-sm text-slate-600 dark:text-slate-300">{authorMember?.data.title ?? "Editör"}</div>
            </div>
          </div>
        </header>

        <div class="prose prose-slate mt-10 dark:prose-invert">
          <span class="sr-only" data-pagefind-filter="kategori">{article.data.category}</span>
          <span class="sr-only" data-pagefind-filter="yazar">{article.data.author}</span>
          <slot />
        </div>

        {
          relatedArticles.length > 0 && (
            <section class="mt-16" data-pagefind-ignore>
              <div class="flex items-end justify-between gap-4">
                <div>
                  <p class="section-eyebrow">İlgili İçerikler</p>
                  <h2 class="mt-4 font-display text-3xl font-semibold text-slate-950 dark:text-white">Aynı kategoriden devam edin</h2>
                </div>
              </div>
              <div class="mt-8 grid gap-6 lg:grid-cols-3">
                {relatedArticles.map((related) => <ArticleCard article={related} />)}
              </div>
            </section>
          )
        }

        <section class="mt-12 grid gap-4 md:grid-cols-2" data-pagefind-ignore>
          {
            newerArticle ? (
              <a href={withBase(`/makaleler/${entrySlug(newerArticle.id)}/`)} class="surface-card p-5">
                <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Daha yeni</div>
                <div class="mt-2 font-display text-xl font-semibold text-slate-900 dark:text-white">{newerArticle.data.title}</div>
              </a>
            ) : (
              <div class="surface-card border-dashed p-5 text-sm text-slate-500 dark:text-slate-400">Bu yazı için daha yeni bir makale bulunmuyor.</div>
            )
          }

          {
            olderArticle ? (
              <a href={withBase(`/makaleler/${entrySlug(olderArticle.id)}/`)} class="surface-card p-5">
                <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Daha eski</div>
                <div class="mt-2 font-display text-xl font-semibold text-slate-900 dark:text-white">{olderArticle.data.title}</div>
              </a>
            ) : (
              <div class="surface-card border-dashed p-5 text-sm text-slate-500 dark:text-slate-400">Bu yazı için daha eski bir makale bulunmuyor.</div>
            )
          }
        </section>
      </article>

      <aside class="space-y-6 xl:sticky xl:top-24 xl:self-start">
        <TableOfContents headings={headings} />
        <ShareButtons title={article.data.title} url={shareUrl} />
      </aside>
    </div>
  </section>

  <script is:inline>
    for (const progressBar of document.querySelectorAll("[data-scroll-progress]")) {
      if (progressBar.dataset.ready === "true") continue;
      progressBar.dataset.ready = "true";

      const syncProgress = () => {
        const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = totalHeight > 0 ? Math.min(100, (window.scrollY / totalHeight) * 100) : 0;
        progressBar.style.width = `${ratio}%`;
      };

      syncProgress();
      window.addEventListener("scroll", syncProgress, { passive: true });
    }
  </script>
</BaseLayout>
