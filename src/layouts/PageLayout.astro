---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  canonicalPath?: string;
  searchable?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  eyebrow = "Bilgi Sayfası",
  canonicalPath,
  searchable = true,
  structuredData
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  searchable={searchable}
  structuredData={structuredData}
>
  <section class="container-shell py-12 lg:py-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-eyebrow">{eyebrow}</p>
      <h1 class="mt-5 font-display text-4xl font-semibold text-slate-950 dark:text-white sm:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{description}</p>
    </div>

    <div class="mx-auto mt-12 max-w-4xl">
      <article class="surface-card p-6 sm:p-8 lg:p-10">
        <div class="prose prose-slate dark:prose-invert">
          <slot />
        </div>
      </article>
    </div>

    <slot name="afterContent" />
  </section>
</BaseLayout>
